{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FeatureMappingOutput",
  "type": "object",
  "required": [
    "feature_validation_table",
    "overall_tfs_score",
    "production_tfs_score"
  ],
  "properties": {
    "feature_validation_table": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["proposed_feature", "canonical_capability", "integration_path", "tfs_score", "poc_readiness"],
        "properties": {
          "proposed_feature": { "type": "string" },
          "canonical_capability": { "type": "string" },
          "integration_path": { "type": "string" },
          "tfs_score": { "type": "integer", "minimum": 0, "maximum": 100 },
          "poc_readiness": { "type": "string", "enum": ["Ready", "Roadmap-Blocked", "Incompatible"] }
        }
      }
    },
    "overall_tfs_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "production_tfs_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "sandbox_poc_scope": {
      "type": "object",
      "properties": {
        "required_nodes": { "type": "integer" },
        "test_apis": {
          "type": "array",
          "items": { "type": "string" }
        },
        "estimated_setup_weeks": { "type": "integer" }
      }
    }
  }
}
